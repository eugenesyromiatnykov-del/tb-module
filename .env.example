# --- Supabase (frontend) ---------------------------------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# --- Server-only (Vercel env, NEVER prefix with VITE_) ---------------------
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# bcrypt hash of the practice PIN.
# Generate locally: `npm run hash-pin -- 12345678` (after `npm install`).
PIN_HASH=$2a$12$REPLACE_WITH_REAL_HASH

# JWT signing secret (HS256). Generate: `openssl rand -base64 48`.
JWT_SECRET=replace-with-48-bytes-base64

# Resend API key (Phase 2 onward).
RESEND_API_KEY=re_...

# From-address for digest emails. Use a verified Resend domain in production.
# Sandbox default works for testing but is rate-limited.
DIGEST_FROM=Модуль ТБ <onboarding@resend.dev>

# Comma-separated digest recipients (Phase 2).
DIGEST_RECIPIENTS=eugene.syromiatnykov@gmail.com,knecolena@gmail.com

# Vercel Cron auth secret. Set this and Vercel will send it as
# Authorization: Bearer <secret>. Otherwise the endpoint is open.
CRON_SECRET=

# Public URL of the deployed app (used in email links).
APP_URL=https://tb-module.vercel.app

# Optional: Upstash Redis for brute-force lockout.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
